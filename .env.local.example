# Copy this file to .env.local and fill in your keys
# .env.local is git-ignored — your keys stay private

# Anthropic API key — voor AI Quickscan streaming analyse en actieplan generatie
# Krijg een key via: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — voor contactformulier en quickscan actieplan e-mail
# Krijg een key via: https://resend.com/
RESEND_API_KEY=re_...

# Google Gemini API key (voor het genereren van site-afbeeldingen)
# Krijg een key via: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Google site verification (optioneel)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# Google Analytics (optioneel)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# Brevo API key - voor nieuwsbrief inschrijvingen
# Krijg een key via: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# Brevo lijst ID - Limburg AI Labs lijst
BREVO_LIST_ID=3

# Twenty CRM - voor lead capture (AI quickscan + toegankelijkheidsaudit)
# 1. Deploy Twenty (Railway / Contabo)
# 2. Genereer API key in Twenty: Settings → API & Webhooks → API Keys → Create
# 3. De key is een JWT token (begint met "eyJ", 200+ chars)
TWENTY_API_KEY=eyJ...
TWENTY_BASE_URL=https://crm.maisonblender.com

# ElevenLabs - voor voice-upgrade van de Brand Ambassador (Optie C: Hybrid)
# Zonder deze keys valt voice terug op de ingebouwde SpeechSynthesis API.
# Krijg een key via: https://elevenlabs.io/app/settings/api-keys
#
# - ELEVENLABS_API_KEY: vereist voor TTS (read-aloud) + ConvAI (live gesprek)
# - ELEVENLABS_VOICE_ID: optioneel; default is "Charlotte" (multilingual v2)
#   Bekijk voices op https://elevenlabs.io/app/voice-library
# - ELEVENLABS_MODEL_ID: optioneel; default is "eleven_multilingual_v2".
#   Gebruik "eleven_flash_v2_5" voor lagere latency (minder expressief).
# - ELEVENLABS_AGENT_ID: alleen nodig voor "Praat live"-knop.
#   Maak een agent op https://elevenlabs.io/app/conversational-ai en plak
#   de agent_id hier. Zonder deze var blijft de knop verborgen.
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_AGENT_ID=
