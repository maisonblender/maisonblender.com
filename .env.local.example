# Copy this file to .env.local and fill in your keys
# .env.local is git-ignored — your keys stay private

# Anthropic API key — voor AI Quickscan streaming analyse en actieplan generatie
# Krijg een key via: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — voor contactformulier en quickscan actieplan e-mail
# Krijg een key via: https://resend.com/
RESEND_API_KEY=re_...

# Google Gemini API key (voor het genereren van site-afbeeldingen)
# Krijg een key via: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Google site verification (optioneel)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# Google Analytics (optioneel)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
